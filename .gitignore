# ============================================================
# Root .gitignore for DiabetesMonitoringHub
# ============================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.idea/
.vscode/
*.iml
*.iws
*.ipr

# Environment & secrets (NEVER commit these)
.env
.env.*
!.env.example
*.pem
*.key
*.jks
*.p8
*.p12
*.mobileprovision

# Backend local config overrides
**/application-local.properties
**/application-dev.properties

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
target/
build/
dist/

# Large binary files (already in repo root - consider removing from git history)
*.zip
*.msi
*.exe

# TypeScript build info
*.tsbuildinfo
