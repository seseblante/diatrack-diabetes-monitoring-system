## ============================================================
## application.properties.example
## ============================================================
## Copy this file to application-local.properties (gitignored)
## and fill in real values, OR export the variables below as
## environment variables before starting the app.
##
## NEVER commit real credentials to version control.
## ============================================================

# ===============================
# Application
# ===============================
spring.application.name=hub-backend

# ===============================
# Server
# ===============================
server.port=${PORT:8080}

# ===============================
# Database
# -- Set these environment variables --
# DB_URL      e.g. jdbc:postgresql://localhost:5432/HUB-DB
# DB_USERNAME e.g. postgres
# DB_PASSWORD e.g. yourpassword
# ===============================
spring.datasource.url=${DB_URL}
spring.datasource.username=${DB_USERNAME}
spring.datasource.password=${DB_PASSWORD}
spring.datasource.driver-class-name=org.postgresql.Driver

# ===============================
# JPA / Hibernate
# ===============================
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.hibernate.ddl-auto=validate
spring.jpa.show-sql=false
spring.jpa.open-in-view=false

# ===============================
# Security
# -- Set these environment variables --
# JWT_SECRET_KEY              A Base64-encoded random secret ≥ 256 bits
#                             Generate with: openssl rand -base64 32
# SPRING_SECURITY_USER_NAME   (optional, default: admin)
# SPRING_SECURITY_USER_PASSWORD  A strong password for the Spring actuator user
# ===============================
application.security.jwt.secret-key=${JWT_SECRET_KEY}
spring.security.user.name=${SPRING_SECURITY_USER_NAME:admin}
spring.security.user.password=${SPRING_SECURITY_USER_PASSWORD}

# ===============================
# CORS
# -- Set CORS_ALLOWED_ORIGINS to your frontend URL(s) --
# e.g. http://localhost:5173 or https://your-app.vercel.app
# ===============================
app.cors.allowed-origins=${CORS_ALLOWED_ORIGINS:http://localhost:5173}
